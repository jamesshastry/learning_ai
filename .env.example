# Copy this to .env and fill in at least one API key.
# The system auto-detects which provider to use based on available keys.
# You can also set LLM_PROVIDER=claude|gemini|none to force a choice.

# Anthropic Claude API key (for claude-sonnet/opus models)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini API key (for gemini-2.5-flash — free tier available)
GEMINI_API_KEY=your-gemini-key-here

# Or skip both for transcribe-only mode (no notes, just transcripts)
